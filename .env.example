APP_DATABASE_URL=sqlite:///./ai_sql_copilot.db
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b
DEFAULT_SQL_LIMIT=100
STATEMENT_TIMEOUT_MS=15000
READ_ONLY_EXECUTION=true
PUBLIC_DEMO=false
USE_LOCAL_LLM=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_STORAGE_SEED_DEFAULT_CONNECTION=false
APP_STORAGE_DEFAULT_CONNECTION_NAME=Local Demo Postgres
APP_STORAGE_DEFAULT_CONNECTION_HOST=127.0.0.1
APP_STORAGE_DEFAULT_CONNECTION_PORT=5432
APP_STORAGE_DEFAULT_CONNECTION_DATABASE=ai_sql_copilot_demo
APP_STORAGE_DEFAULT_CONNECTION_USERNAME=postgres
APP_STORAGE_DEFAULT_CONNECTION_PASSWORD_ENV_VAR=

# Example target database password reference.
# When creating a connection, set password_env_var to this variable name.
TARGET_POSTGRES_PASSWORD=
